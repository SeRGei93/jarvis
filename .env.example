# ─────────────────────────────────────────────────────────────
# jarvis — deployment env (root). Consumed by docker-compose, injected into the
# `app` container (env_file). TLS + the public domain are handled by an EXTERNAL
# Caddy (shared `edge` network → reverse_proxy jarvis-app:8080).
# Copy to `.env` (or run `make env`). NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# ── Deployment ───────────────────────────────────────────────
# Public domain the external Caddy serves / the Mini App origin (informational
# here; the Caddy config is what actually binds it). Mini App → https://<domain>/miniapp.
DOMAIN=jarvis.example.com

# ── Secrets / app config (see backend/.env.example for the full reference) ───
TELEGRAM_BOT_TOKEN=
# Optional webhook mode (default: long polling). Webhook needs the public HTTPS URL.
TELEGRAM_USE_WEBHOOK=
TELEGRAM_WEBHOOK_URL=

# LLM providers (OPENROUTER is required; others optional).
OPENROUTER_API_KEY=
ZAI_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GOOGLE_API_KEY=

# ── Web search (searxng) ─────────────────────────────────────
# Required by the searxng container (generate e.g. `openssl rand -hex 32`).
SEARXNG_SECRET=
# Internal docker URL the backend uses to reach searxng; leave as-is for compose.
SEARXNG_URL=http://searxng:8080
# Optional engine override (comma-separated).
# SEARXNG_ENGINES=
# Optional — local compose host port for the searxng UI (debugging).
# SEARXNG_PORT=8888
# Optional — web fetch/search cache dir (container default: /data/web-cache).
# WEB_CACHE_DIR=

# Admin Mini App bootstrap — comma-separated Telegram user ids (REQUIRED to use
# the admin; empty = deny all admin access).
ADMIN_USER_IDS=

# Runtime (sane defaults for the container; usually leave as-is).
NODE_ENV=production
LOG_LEVEL=info
PORT=8080
# libSQL file lives on the jarvis-data volume (mounted at /data in the container).
LIBSQL_URL=file:/data/avocado.db
LIBSQL_AUTH_TOKEN=
