# dependencies & build output (re-built inside the image)
**/node_modules
**/dist

# local data / secrets — never bake into an image
**/data
**/*.db
**/*.db-journal
**/*.db-wal
**/*.db-shm
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# tests are not needed in the runtime image
backend/test
**/coverage

# vcs / tooling / docs
.git
.github
.ai-factory
.claude
**/*.log
.DS_Store
.idea
.vscode
deploy/letsencrypt
