# ─────────────────────────────────────────────────────────────
# jarvis — secrets ONLY. All other config lives in the database
# (model roles, timeouts, agent params, skills, prompts, plans,
#  MCP servers) and is editable from the admin Mini App. See ROADMAP §4.
# ─────────────────────────────────────────────────────────────

# libSQL / Turso — local file by default; libsql://<db>.turso.io in prod
LIBSQL_URL=file:./data/avocado.db
LIBSQL_AUTH_TOKEN=

# Telegram
TELEGRAM_BOT_TOKEN=
# Optional webhook mode (default: long polling). Minimal in M6; hardened in M8.
# Set TELEGRAM_USE_WEBHOOK=1 and a public TELEGRAM_WEBHOOK_URL (its path is served
# by the built-in HTTP server, e.g. https://example.com/telegram).
TELEGRAM_USE_WEBHOOK=
TELEGRAM_WEBHOOK_URL=

# LLM providers
OPENROUTER_API_KEY=
ZAI_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GOOGLE_API_KEY=

# Admin Mini App (M8) — comma-separated Telegram user ids that may open the admin.
# REQUIRED to use the admin API: an empty list denies ALL /admin/api requests
# (deny-by-default). This is the bootstrap admin gate; distinct from the in-DB
# `telegram_allowed_users` chat allowlist. Example: ADMIN_USER_IDS=123456,789012
ADMIN_USER_IDS=
# Optional: directory of the built Mini App served as static by the backend.
# Defaults to ../frontend/dist (relative to backend CWD). Built via `cd frontend && npm run build`.
ADMIN_STATIC_DIR=

# Runtime
NODE_ENV=development
LOG_LEVEL=debug
PORT=8080
