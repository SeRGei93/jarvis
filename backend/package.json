{
  "name": "jarvis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personalized AI assistant for Telegram (TypeScript + Mastra). Port of avocado-ai (Go).",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.82",
    "@ai-sdk/openai": "^3.0.71",
    "@ai-sdk/openai-compatible": "^2.0.50",
    "@ai-sdk/xai": "^3.0.95",
    "@hono/node-server": "^1.19.14",
    "@mastra/core": "^1.42.0",
    "@mastra/libsql": "^1.13.0",
    "@mastra/memory": "^1.20.3",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "ai": "^6.0.204",
    "cron-parser": "^5.5.0",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.43.0",
    "hono": "^4.12.25",
    "jsdom": "^28.1.0",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@types/node-cron": "^3.0.11",
    "@types/turndown": "^5.0.6",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
